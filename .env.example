MYSQL_ROOT_PASSWORD=researchrag-root
MYSQL_DATABASE=researchrag
MYSQL_USER=researchrag
MYSQL_PASSWORD=researchrag
JWT_ISSUER=ResearchRAG
JWT_AUDIENCE=ResearchRAG
JWT_SIGNING_KEY=change-me-to-a-long-random-secret-of-at-least-32-bytes
FRONTEND_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:8080
QDRANT_URL=http://qdrant:6333
UPLOAD_ROOT=/app/uploads
CHAT_PROVIDER=echo
EMBEDDING_PROVIDER=hash
RERANKER_PROVIDER=passthrough
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Leave empty to follow the provider-specific embedding model above/below.
EMBEDDING_MODEL=
# From inside Docker, "localhost" is the container itself; host.docker.internal
# reaches an Ollama server on the host (mapped via extra_hosts in compose).
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
EMAIL_FROM=no-reply@researchrag.local
# Leave SMTP_HOST empty to log verification/reset emails to the backend log
# instead of sending them (development default).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_SSL=true

