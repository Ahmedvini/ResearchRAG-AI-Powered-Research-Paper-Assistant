{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=researchrag;User=researchrag;Password=researchrag;"
  },
  "Jwt": {
    "Issuer": "ResearchRAG",
    "Audience": "ResearchRAG",
    "SigningKey": "change-me-to-a-long-random-secret-of-at-least-32-bytes"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Storage": {
    "UploadRoot": "uploads",
    "MaxPdfBytes": 52428800
  },
