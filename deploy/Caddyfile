# SITE_ADDRESS examples:
#   :80                    -> plain HTTP on the VM's IP (default)
#   researchrag.duckdns.org -> automatic HTTPS via Let's Encrypt
{$SITE_ADDRESS::80} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:8080
	}
	handle /swagger* {
		reverse_proxy backend:8080
	}
	handle /health {
		reverse_proxy backend:8080
	}
	handle {
		reverse_proxy frontend:80
	}
}
